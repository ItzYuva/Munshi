# Server
PORT=3000

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_here   # pick any random string

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/munshi?retryWrites=true&w=majority

# Your WhatsApp number (for sending reports / alerts to yourself)
OWNER_PHONE=91XXXXXXXXXX
